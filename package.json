{
  "name": "better-character-sheet",
  "version": "0.3.0",
  "description": "A DnDBeyond-inspired character sheet replacement for FoundryVTT dnd5e",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue\"",
    "skill:capture": "node scripts/skill-capture.mjs",
    "skill:retrieve": "node scripts/skill-retrieve.mjs",
    "skill:list": "node scripts/skill-manage.mjs list",
    "skill:manage": "node scripts/skill-manage.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "esbuild-sass-plugin": "^3.7.0",
    "playwright": "^1.59.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
