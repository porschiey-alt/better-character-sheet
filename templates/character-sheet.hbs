<section class="bcs-sheet">
  {{!-- Top Section: Header --}}
  {{> "modules/better-character-sheet/templates/parts/header.hbs"}}

  {{!-- Combined Ability Scores + Stats Row --}}
  <div class="bcs-combined-row">
    {{!-- Left: Ability Scores --}}
    <div class="bcs-row-left">
      {{#each abilities}}
      <div class="bcs-ability" data-ability="{{key}}">
        <div class="bcs-ability-label">{{abbr}}</div>
        <div class="bcs-ability-mod">{{ dnd5e-formatModifier mod }}</div>
        <div class="bcs-ability-score">{{value}}</div>
      </div>
      {{/each}}
    </div>

    {{!-- Right: Prof, Speed, Inspiration + HP --}}
    <div class="bcs-row-right">
      <div class="bcs-stat-block">
        <div class="bcs-stat-value">{{ dnd5e-numberFormat system.attributes.prof signDisplay="always" }}</div>
        <div class="bcs-stat-sublabel">Prof</div>
      </div>

      <div class="bcs-stat-block">
        <div class="bcs-stat-value">{{system.attributes.movement.walk}}</div>
        <div class="bcs-stat-sublabel">Speed</div>
      </div>

      <div class="bcs-stat-block bcs-inspiration {{#if system.attributes.inspiration}}active{{/if}}"
        data-action="toggleInspiration">
        <i class="fas fa-star bcs-stat-bg-icon"></i>
        <div class="bcs-stat-value">
          <i class="{{#if system.attributes.inspiration}}fas{{else}}far{{/if}} fa-star"></i>
        </div>
        <div class="bcs-stat-sublabel">Heroic</div>
      </div>

      {{#if showDeathSaves}}
      {{!-- Death Saves — replaces HP block when HP is 0 --}}
      <div class="bcs-death-saves-inline">
        <div class="bcs-ds-inline-header">
          <div class="bcs-ds-inline-label"><i class="fas fa-skull"></i> Death Saves</div>
          <div class="bcs-ds-hp-mini">
            <span class="bcs-hp-current">0</span>
            <span class="bcs-hp-sep">/</span>
            <span class="bcs-hp-max">{{system.attributes.hp.effectiveMax}}</span>
          </div>
        </div>
        <div class="bcs-ds-body">
          <div class="bcs-ds-group">
            <span class="bcs-ds-group-label success-label"><i class="fas fa-check"></i></span>
            <span class="bcs-ds-pips">
              <span class="bcs-ds-pip {{#if system.attributes.death.success}}success{{/if}}" data-ds-type="success" data-ds-index="1">●</span>
              <span class="bcs-ds-pip {{#if (gte system.attributes.death.success 2)}}success{{/if}}" data-ds-type="success" data-ds-index="2">●</span>
              <span class="bcs-ds-pip {{#if (gte system.attributes.death.success 3)}}success{{/if}}" data-ds-type="success" data-ds-index="3">●</span>
            </span>
          </div>
          <div class="bcs-ds-group">
            <span class="bcs-ds-group-label failure-label"><i class="fas fa-times"></i></span>
            <span class="bcs-ds-pips">
              <span class="bcs-ds-pip {{#if system.attributes.death.failure}}failure{{/if}}" data-ds-type="failure" data-ds-index="1">●</span>
              <span class="bcs-ds-pip {{#if (gte system.attributes.death.failure 2)}}failure{{/if}}" data-ds-type="failure" data-ds-index="2">●</span>
              <span class="bcs-ds-pip {{#if (gte system.attributes.death.failure 3)}}failure{{/if}}" data-ds-type="failure" data-ds-index="3">●</span>
            </span>
          </div>
          <button type="button" class="bcs-ds-roll-btn" title="Roll Death Save">
            <i class="fas fa-dice-d20"></i> Roll
          </button>
          <button type="button" class="bcs-hp-btn bcs-heal-btn bcs-ds-heal-btn" data-action="heal">
            <i class="fas fa-heart"></i> Heal
          </button>
        </div>
      </div>
      {{else}}
      {{!-- HP Block: [Input] [Heal/Dmg buttons] [HP readout] --}}
      <div class="bcs-hp-block">
        <input type="number" class="bcs-hp-input" placeholder="0" data-hp-amount />
        <div class="bcs-hp-buttons">
          <button type="button" class="bcs-hp-btn bcs-heal-btn" data-action="heal">
            <i class="fas fa-heart"></i> Heal
          </button>
          <button type="button" class="bcs-hp-btn bcs-damage-btn" data-action="damage">
            <i class="fas fa-minus-circle"></i> Dmg
          </button>
        </div>
        <div class="bcs-hp-info">
          <div class="bcs-hp-label-top">Hit Points</div>
          <div class="bcs-hp-numbers">
            <span class="bcs-hp-current">{{system.attributes.hp.value}}</span>
            <span class="bcs-hp-sep">/</span>
            <span class="bcs-hp-max">{{system.attributes.hp.effectiveMax}}</span>
            <span class="bcs-hp-temp-sep">+</span>
            <span class="bcs-hp-temp">{{system.attributes.hp.temp}}</span>
            <span class="bcs-hp-temp-label">temp</span>
          </div>
        </div>
      </div>
      {{/if}}
    </div>
  </div>

  {{!-- Main 3-Column Layout --}}
  <div class="bcs-main">
    {{!-- Left Column: Saves, Passives, Senses, Proficiencies --}}
    <div class="bcs-col-left">
      {{> "modules/better-character-sheet/templates/parts/sidebar.hbs"}}
    </div>

    {{!-- Middle Column: Skills --}}
    <div class="bcs-col-mid">
      {{> "modules/better-character-sheet/templates/parts/skills.hbs"}}
    </div>

    {{!-- Right Column: Combat cards + Tabbed Content --}}
    <div class="bcs-col-right">
      {{!-- Combat row: AC, Initiative, Defenses/Conditions --}}
      <div class="bcs-combat-row">
        <div class="bcs-combat-card bcs-combat-ac bcs-clickable" data-action="open-ac">
          <i class="fas fa-shield-alt bcs-combat-card-bg"></i>
          <div class="bcs-combat-card-value">{{system.attributes.ac.value}}</div>
          <div class="bcs-combat-card-label">Armor Class</div>
        </div>

        <div class="bcs-combat-card bcs-combat-init">
          <div class="bcs-combat-card-value">{{ dnd5e-numberFormat system.attributes.init.total signDisplay="always" }}</div>
          <div class="bcs-combat-card-label">Initiative</div>
        </div>

        <div class="bcs-combat-card bcs-combat-defenses bcs-clickable" data-action="open-conditions">
          <div class="bcs-combat-card-label">Defenses &amp; Conditions</div>
          <div class="bcs-defense-tags">
            {{#each resistances}}<span class="bcs-defense-tag resist">Resist {{this}}</span>{{/each}}
            {{#each immunities}}<span class="bcs-defense-tag immune">Immune {{this}}</span>{{/each}}
            {{#each conditionImmunities}}<span class="bcs-defense-tag cond-immune">{{this}} Immune</span>{{/each}}
            {{#each conditions}}<span class="bcs-defense-tag condition">{{this}}</span>{{/each}}
            {{#if exhaustionLevel}}<span class="bcs-defense-tag condition">Exhaustion {{exhaustionLevel}}</span>{{/if}}
            {{#unless hasDefenses}}<span class="bcs-defense-none">None</span>{{/unless}}
          </div>
        </div>
      </div>

      <nav class="bcs-tab-nav">
        <button class="bcs-tab-btn active" data-bcs-tab="actions">Actions</button>
        <button class="bcs-tab-btn" data-bcs-tab="spells">Spells</button>
        <button class="bcs-tab-btn" data-bcs-tab="inventory">Inventory</button>
        <button class="bcs-tab-btn" data-bcs-tab="features">Features</button>
        <button class="bcs-tab-btn" data-bcs-tab="background">Background</button>
        <button class="bcs-tab-btn" data-bcs-tab="notes">Notes</button>
        <button class="bcs-tab-btn" data-bcs-tab="extras">Extras</button>
      </nav>
      <div class="bcs-tab-content">
        <div class="bcs-tab-pane active" data-bcs-tab-pane="actions">
          {{> "modules/better-character-sheet/templates/tabs/actions.hbs"}}
        </div>
        <div class="bcs-tab-pane" data-bcs-tab-pane="spells">
          {{> "modules/better-character-sheet/templates/tabs/spells.hbs"}}
        </div>
        <div class="bcs-tab-pane" data-bcs-tab-pane="inventory">
          {{> "modules/better-character-sheet/templates/tabs/inventory.hbs"}}
        </div>
        <div class="bcs-tab-pane" data-bcs-tab-pane="features">
          {{> "modules/better-character-sheet/templates/tabs/features.hbs"}}
        </div>
        <div class="bcs-tab-pane" data-bcs-tab-pane="background">
          {{> "modules/better-character-sheet/templates/tabs/background.hbs"}}
        </div>
        <div class="bcs-tab-pane" data-bcs-tab-pane="notes">
          {{> "modules/better-character-sheet/templates/tabs/notes.hbs"}}
        </div>
        <div class="bcs-tab-pane" data-bcs-tab-pane="extras">
          {{> "modules/better-character-sheet/templates/tabs/extras.hbs"}}
        </div>
      </div>
    </div>
  </div>

  {{!-- Slide-out detail panel --}}
  <div class="bcs-detail-panel" data-panel="closed">
    <div class="bcs-detail-header">
      <h3 class="bcs-detail-title"></h3>
      <button type="button" class="bcs-detail-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="bcs-detail-spell-meta" style="display:none;"></div>
    <div class="bcs-detail-actions" style="display:none;">
      <button type="button" class="bcs-detail-cast-btn"><i class="fas fa-magic"></i> Cast Spell</button>
      <div class="bcs-detail-upcast"></div>
    </div>
    <div class="bcs-detail-body"></div>
  </div>

  {{!-- Spell Management panel --}}
  <div class="bcs-manage-panel" data-panel="closed">
    <div class="bcs-manage-header">
      <h3 class="bcs-manage-title"><i class="fas fa-book-open"></i> Manage Spells</h3>
      <button type="button" class="bcs-manage-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="bcs-manage-learn-bar" style="display:none;">
      <button type="button" class="bcs-manage-learn-toggle"><i class="fas fa-scroll"></i> Learn New Spells</button>
    </div>
    <div class="bcs-manage-wizard-add" style="display:none;">
      <div class="bcs-manage-search-row">
        <input type="text" class="bcs-manage-search" placeholder="Filter spells…" />
        <select class="bcs-manage-level-filter">
          <option value="all">All Levels</option>
          <option value="1">1st</option>
          <option value="2">2nd</option>
          <option value="3">3rd</option>
          <option value="4">4th</option>
          <option value="5">5th</option>
          <option value="6">6th</option>
          <option value="7">7th</option>
          <option value="8">8th</option>
          <option value="9">9th</option>
        </select>
      </div>
      <div class="bcs-manage-search-results"></div>
    </div>
    <div class="bcs-manage-body"></div>
  </div>

  {{!-- Currency editing panel --}}
  <div class="bcs-currency-panel" data-panel="closed">
    <div class="bcs-panel-header">
      <h3 class="bcs-panel-title"><i class="fas fa-coins"></i> Currency</h3>
      <button type="button" class="bcs-currency-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="bcs-panel-body">
      <div class="bcs-currency-row">
        <label>Platinum (PP)</label>
        <input type="number" class="bcs-currency-input" data-currency="pp" value="{{currency.pp}}" min="0" />
      </div>
      <div class="bcs-currency-row">
        <label>Gold (GP)</label>
        <input type="number" class="bcs-currency-input" data-currency="gp" value="{{currency.gp}}" min="0" />
      </div>
      <div class="bcs-currency-row">
        <label>Electrum (EP)</label>
        <input type="number" class="bcs-currency-input" data-currency="ep" value="{{currency.ep}}" min="0" />
      </div>
      <div class="bcs-currency-row">
        <label>Silver (SP)</label>
        <input type="number" class="bcs-currency-input" data-currency="sp" value="{{currency.sp}}" min="0" />
      </div>
      <div class="bcs-currency-row">
        <label>Copper (CP)</label>
        <input type="number" class="bcs-currency-input" data-currency="cp" value="{{currency.cp}}" min="0" />
      </div>
      <button type="button" class="bcs-panel-apply bcs-currency-apply">Apply</button>
    </div>
  </div>

  {{!-- AC editing panel --}}
  <div class="bcs-ac-panel" data-panel="closed">
    <div class="bcs-panel-header">
      <h3 class="bcs-panel-title"><i class="fas fa-shield-alt"></i> Armor Class</h3>
      <button type="button" class="bcs-ac-panel-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="bcs-panel-body">
      <div class="bcs-ac-summary">
        <span class="bcs-ac-summary-label">Computed AC</span>
        <span class="bcs-ac-summary-value">{{system.attributes.ac.value}}</span>
      </div>
      <div class="bcs-hp-edit-row">
        <label>AC Bonus / Penalty</label>
        <input type="number" class="bcs-hp-edit-input" data-ac-field="bonus" value="{{system.attributes.ac.bonus}}" />
      </div>
      <div class="bcs-hp-edit-row">
        <label>Flat Override <span class="bcs-field-hint">(leave empty to use normal calculation)</span></label>
        <input type="number" class="bcs-hp-edit-input" data-ac-field="flat" value="{{system.attributes.ac.flat}}" placeholder="—" />
      </div>
      <button type="button" class="bcs-panel-apply bcs-ac-panel-apply">Apply</button>
    </div>
  </div>

  {{!-- HP editing panel --}}
  <div class="bcs-hp-panel" data-panel="closed">
    <div class="bcs-panel-header">
      <h3 class="bcs-panel-title"><i class="fas fa-heart"></i> Hit Points</h3>
      <button type="button" class="bcs-hp-panel-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="bcs-panel-body">
      <div class="bcs-hp-edit-row">
        <label>Current HP</label>
        <input type="number" class="bcs-hp-edit-input" data-hp-field="value" value="{{system.attributes.hp.value}}" min="0" />
      </div>
      <div class="bcs-hp-edit-row">
        <label>Max HP</label>
        <input type="number" class="bcs-hp-edit-input" data-hp-field="max" value="{{system.attributes.hp.max}}" min="0" />
      </div>
      <div class="bcs-hp-edit-row">
        <label>Temp HP</label>
        <input type="number" class="bcs-hp-edit-input" data-hp-field="temp" value="{{system.attributes.hp.temp}}" min="0" />
      </div>
      <button type="button" class="bcs-panel-apply bcs-hp-panel-apply">Apply</button>
    </div>
  </div>

  {{!-- Conditions panel --}}
  <div class="bcs-conditions-panel" data-panel="closed">
    <div class="bcs-panel-header">
      <h3 class="bcs-panel-title"><i class="fas fa-exclamation-triangle"></i> Conditions</h3>
      <button type="button" class="bcs-conditions-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="bcs-panel-body">
      <div class="bcs-exhaustion-control">
        <label>Exhaustion Level</label>
        <div class="bcs-exhaustion-stepper">
          <button type="button" class="bcs-exhaustion-btn" data-exhaustion-dir="down"><i class="fas fa-minus"></i></button>
          <span class="bcs-exhaustion-value">{{exhaustionLevel}}</span>
          <button type="button" class="bcs-exhaustion-btn" data-exhaustion-dir="up"><i class="fas fa-plus"></i></button>
        </div>
      </div>
      <div class="bcs-condition-list">
        {{#each conditionTypes}}
        <div class="bcs-condition-row" data-condition-id="{{this.id}}">
          <img class="bcs-condition-icon" src="{{this.icon}}" alt="{{this.label}}" />
          <span class="bcs-condition-label">{{this.label}}</span>
          <div class="bcs-condition-toggle {{#if this.active}}active{{/if}}">
            <div class="bcs-condition-toggle-track">
              <div class="bcs-condition-toggle-thumb"></div>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </div>

  {{!-- Theme settings button (bottom-left) --}}
  <button type="button" class="bcs-theme-toggle" title="Customize Theme">
    <i class="fas fa-palette"></i>
  </button>

  {{!-- Theme panel (slides from left) --}}
  <div class="bcs-theme-panel" data-panel="closed">
    <div class="bcs-theme-header">
      <h3 class="bcs-theme-title">Customize Theme</h3>
      <button type="button" class="bcs-theme-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="bcs-theme-body">
      <div class="bcs-theme-field">
        <label>Accent Color</label>
        <input type="color" class="bcs-theme-input" data-theme="accentColor" value="{{themeAccent}}" />
      </div>
      <div class="bcs-theme-field">
        <label>Background Tint</label>
        <input type="color" class="bcs-theme-input" data-theme="bgColor" value="{{themeBg}}" />
      </div>
      <div class="bcs-theme-actions">
        <button type="button" class="bcs-theme-reset">Reset to Default</button>
      </div>
    </div>
  </div>
</section>
